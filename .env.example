PAPERCLIP_ENABLED=true
PAPERCLIP_MODE=subprocess
PAPERCLIP_COMMAND=./venv/bin/python scripts/paperclip_local.py
PAPERCLIP_HTTP_URL=http://127.0.0.1:3100
PAPERCLIP_HTTP_MODE=paperclip
PAPERCLIP_COMPANY_ID=<your-company-id>
PAPERCLIP_AGENT_ID=<your-agent-id>
PAPERCLIP_TIMEOUT=300
PAPERCLIP_POLL_TIMEOUT=300

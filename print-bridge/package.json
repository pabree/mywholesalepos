{
  "name": "stery-pos-print-bridge",
  "version": "1.0.0",
  "private": true,
  "description": "Local print bridge for Stery POS receipts",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "check": "node -c server.js",
    "build:win": "pkg . --targets node18-win-x64 --output dist/stery-print-bridge.exe"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "node-thermal-printer": "^4.5.1"
  }
